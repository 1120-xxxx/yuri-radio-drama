---
import '@unocss/reset/tailwind.css';
import '../styles/global.css';
const {
  title = '百合广播剧数据可视化平台',
  description = '聚合百合广播剧元数据，CV 信息，匿名评分与可视化榜单',
} = Astro.props;
const navItems = [
  { href: '/', label: '首页' },
  { href: '/rank/', label: '排行榜' },
  { href: '/cv-universe/', label: 'CV 宇宙' },
  { href: '/dramas/', label: '剧集库' },
  { href: '/cvs/', label: 'CV 索引' },
];
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1F2A38" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <header class="sticky top-0 z-20 bg-bg-nav border-b border-border-soft shadow-lg">
      <div class="container flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3 font-bold text-lg">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-2xl bg-gradient-to-br from-accent to-accent-end shadow-lg">
            <span class="text-lg">🌸</span>
          </span>
          <span class="text-text-nav">
            百合广播剧数据站
          </span>
        </a>
        <nav class="hidden md:flex gap-1 items-center">
          {navItems.map((item) => {
            const active =
              item.href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(item.href.replace(/\/$/, ''));
            return (
              <a
                href={item.href}
                class={[
                  'px-4 py-2 rounded-xl text-sm font-medium transition-all',
                  active
                    ? 'bg-gradient-to-r from-accent/30 to-accent-end/30 text-white border border-accent/40'
                    : 'text-text-nav/80 hover:text-text-nav hover:bg-white/10',
                ].join(' ')}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
        <button
          id="nav-toggle"
          class="md:hidden p-2 rounded-xl hover:bg-white/10 transition-colors"
          aria-label="展开菜单"
        >
          <span class="block w-5 h-0.5 bg-text-nav mb-1" />
          <span class="block w-5 h-0.5 bg-text-nav mb-1" />
          <span class="block w-5 h-0.5 bg-text-nav" />
        </button>
      </div>
      <nav
        id="mobile-nav"
        class="md:hidden hidden border-t border-border-soft bg-bg-nav"
      >
        <ul class="container py-2 flex flex-col">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="block py-2 text-text-nav/80 hover:text-text-nav hover:bg-white/10 transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main class="container py-10">
      <slot />
    </main>

    <footer class="border-t border-border-soft mt-20">
      <div class="container py-8 text-sm text-text-muted flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span>© {new Date().getFullYear()}</span>
          <span class="text-text-soft">百合广播剧数据站</span>
          <span class="text-text-faint">·</span>
          <span>匿名评分 · 数据仅供爱好者参考</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('nav-toggle')?.addEventListener('click', () => {
        const el = document.getElementById('mobile-nav');
        if (el) el.classList.toggle('hidden');
      });
    </script>
    {import.meta.env.PROD && import.meta.env.VERCEL && (
      <script>
        import { inject } from '@vercel/analytics';
        inject();
      </script>
    )}
  </body>
</html>
