---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CvSearch from '../../islands/CvSearch.vue';
import { getAllCvs } from '../../lib/data';

const cvs = await getAllCvs();
---

<BaseLayout title="CV 索引 · 百合广播剧数据站">
  <header class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold mb-2">
      <span class="bg-gradient-to-r from-accent-300 via-brand-300 to-gold-400 bg-clip-text text-transparent">CV 索引</span>
    </h1>
    <p class="text-text-muted">共收录 <span class="text-text-soft font-semibold">{cvs.length}</span> 位配音演员。</p>
  </header>

  <!-- CV 搜索栏 -->
  <section class="mb-8">
    <CvSearch client:load cvs={cvs} />
  </section>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {cvs.map((cv) => (
      <a href={`/cvs/${cv.id}/`} class="card hover:border-brand-500/40 hover:-translate-y-1 transition-all">
        <div class="flex items-center gap-4">
          {cv.avatar_url ? (
            <img src={cv.avatar_url} alt={cv.name} class="w-14 h-14 rounded-2xl object-cover bg-gradient-to-br from-brand-400/20 to-accent-400/20" loading="lazy" />
          ) : (
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-400 via-accent-400 to-cyanx-500 flex items-center justify-center text-2xl text-white font-bold shadow-lg shadow-brand-500/20">
              {cv.name.slice(0, 1)}
            </div>
          )}
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-text truncate">{cv.name}</div>
            {cv.bio && <p class="text-xs text-text-muted mt-1 line-clamp-2">{cv.bio}</p>}
          </div>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
