---
import BaseLayout from '../layouts/BaseLayout.astro';
import CvUniverse from '../islands/CvUniverse.vue';
import { getCvCollaborations } from '../lib/data';

const collaborations = await getCvCollaborations(2);
---

<BaseLayout title="CV 宇宙 · 百合广播剧数据站">
  <header class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold mb-2">
      <span class="bg-gradient-to-r from-accent via-accent-end to-cyan bg-clip-text text-transparent">CV 宇宙</span>
    </h1>
    <p class="text-text-muted">探索CV之间的合作关系网络，发现高频合作CP。数据基于已收录的剧集CV关联自动计算。</p>
  </header>

  <CvUniverse client:load collaborations={collaborations} />
</BaseLayout>
