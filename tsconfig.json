{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"~/*": [
				"src/*"
			]
		},
		"jsx": "preserve",
		"allowSyntheticDefaultImports": true,
		"strictNullChecks": true,
		"resolveJsonModule": true
	},
	"include": [
		".astro/types.d.ts",
		"src/**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules",
		"scripts"
	]
}